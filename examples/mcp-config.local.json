{
  "mcpServers": {
    "leads2b": {
      "command": "node",
      "args": ["/absolute/path/to/leads2b-mcp/dist/index.js"],
      "cwd": "/absolute/path/to/leads2b-mcp",
      "env": {
        "LEADS2B_API_V1_TOKEN": "<SEU_TOKEN_V1>",
        "LEADS2B_API_V2_TOKEN": "<SEU_TOKEN_V2>"
      }
    }
  }
}
